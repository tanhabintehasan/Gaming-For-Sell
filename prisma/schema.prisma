generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id                  String   @id @default(uuid())
  nameCn              String
  nameEn              String
  slug                String   @unique
  logoUrl             String?
  bannerUrl           String?
  supportedPlatforms  String   @default("MOBILE,PC")
  description         String?
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  totalSellers        Int      @default(0)
  totalOrders         Int      @default(0)
  totalRevenue        Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  categories          GameCategory[]
  sellerServices      SellerGameService[]
  products            Product[]
  orders              Order[]
  reviews             Review[]

  @@map("games")
}

model GameCategory {
  id                String   @id @default(uuid())
  gameId            String
  name              String
  slug              String
  iconUrl           String?
  description       String?
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  defaultHourlyRate Float?
  minHours          Int      @default(1)
  maxHours          Int      @default(8)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  game     Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  products Product[]
  orders   Order[]

  @@unique([gameId, slug])
  @@map("game_categories")
}

model User {
  id                  String    @id @default(uuid())
  level               String    @default("USER")
  phone               String    @unique
  email               String?   @unique
  username            String    @unique
  avatar              String    @default("/default-avatar.png")
  passwordHash        String
  gender              String?
  age                 Int?
  location            String?
  bio                 String?
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sellerProfile       SellerProfile?
  customerOrders      Order[]        @relation("CustomerOrders")
  sellerOrders        Order[]        @relation("SellerOrders")
  messagesSent        Message[]      @relation("SentMessages")
  messagesReceived    Message[]      @relation("ReceivedMessages")
  withdrawals         Withdrawal[]
  supportTickets      SupportTicket[] @relation("UserSupportTickets")
  adminTickets        SupportTicket[] @relation("AdminSupportTickets")
  adminReplies        SupportReply[] @relation("AdminReplies")
  activityLogs        ActivityLog[]
  reviewsGiven        Review[]       @relation("ReviewCustomer")
  reviewsReceived     Review[]       @relation("ReviewSeller")

  @@map("users")
}

model SellerProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  voiceIntroUrl    String?
  isOnline         Boolean  @default(false)
  lastOnlineAt     DateTime?
  overallRating    Float    @default(5.0)
  totalOrders      Int      @default(0)
  completedOrders  Int      @default(0)
  acceptanceRate   Int      @default(100)
  balance          Float    @default(0)
  totalEarnings    Float    @default(0)
  withdrawalInfo   String?
  isVerified       Boolean  @default(false)
  badges           String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameServices  SellerGameService[]

  @@map("seller_profiles")
}

model SellerGameService {
  id                    String   @id @default(uuid())
  sellerId              String
  gameId                String
  platformTypes         String   @default("MOBILE,PC")
  hourlyRate            Float    @default(50)
  isAvailable           Boolean  @default(true)
  rating                Float    @default(5.0)
  totalOrders           Int      @default(0)
  completedOrders       Int      @default(0)
  availabilitySchedule  String   @default("{}")
  specialties           String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  seller  SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  game    Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([sellerId, gameId])
  @@map("seller_game_services")
}

model Product {
  id              String   @id @default(uuid())
  gameId          String
  categoryId      String?
  sellerId        String?
  name            String
  description     String?
  imageUrl        String?
  audioUrl        String?
  basePrice       Float
  originalPrice   Float?
  serviceType     String   @default("HOURLY")
  durationHours   Int      @default(1)
  specifications  String   @default("{}")
  salesCount      Int      @default(0)
  viewCount       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  game    Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  category GameCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orders  Order[]

  @@map("products")
}

model Order {
  id                String    @id @default(uuid())
  orderNumber       String    @unique
  gameId            String
  customerId        String
  sellerId          String?
  productId         String?
  categoryId        String?
  status            String    @default("PENDING")
  subtotal          Float
  platformFee       Float
  totalAmount       Float
  sellerEarnings    Float
  gamePlatform      String?
  gameIdUsername    String?
  gameServerRegion  String?
  requirements      String?
  notes             String?
  durationHours     Int       @default(1)
  paidAt            DateTime?
  acceptedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  game     Game      @relation(fields: [gameId], references: [id])
  customer User      @relation("CustomerOrders", fields: [customerId], references: [id])
  seller   User?     @relation("SellerOrders", fields: [sellerId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  category GameCategory? @relation(fields: [categoryId], references: [id])
  payments Payment[]
  messages Message[]
  review   Review?

  @@map("orders")
}

model Review {
  id            String   @id @default(uuid())
  orderId       String   @unique
  customerId    String
  sellerId      String
  gameId        String
  rating        Int
  content       String?
  isAnonymous   Boolean  @default(false)
  tags          String   @default("")
  createdAt     DateTime @default(now())

  order    Order  @relation(fields: [orderId], references: [id])
  customer User   @relation("ReviewCustomer", fields: [customerId], references: [id])
  seller   User   @relation("ReviewSeller", fields: [sellerId], references: [id])
  game     Game   @relation(fields: [gameId], references: [id])

  @@map("reviews")
}

model Message {
  id          String    @id @default(uuid())
  orderId     String?
  senderId    String
  receiverId  String
  type        String    @default("TEXT")
  content     String
  fileUrl     String?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  order     Order?  @relation(fields: [orderId], references: [id])
  sender    User    @relation("SentMessages", fields: [senderId], references: [id])
  receiver  User    @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}

model Payment {
  id                String    @id @default(uuid())
  orderId           String?   @unique
  gateway           String
  gatewayPaymentId  String?
  amount            Float
  currency          String    @default("CNY")
  status            String    @default("PENDING")
  gatewayResponse   String?
  metadata          String?   // JSON string storing checkout data before order exists
  paidAt            DateTime?
  createdAt         DateTime  @default(now())

  order Order? @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model AdminConfig {
  id            String    @id @default(uuid())
  configKey     String    @unique
  configValue   String
  isEncrypted   Boolean   @default(false)
  category      String?
  description   String?
  updatedBy     String?
  updatedAt     DateTime  @updatedAt

  @@map("admin_configs")
}

model ContentPage {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  rawContent      String
  renderedContent String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("content_pages")
}

model Withdrawal {
  id            String    @id @default(uuid())
  sellerId      String
  amount        Float
  fee           Float     @default(0)
  netAmount     Float
  method        String
  accountInfo   String
  status        String    @default("PENDING")
  reviewedBy    String?
  reviewNote    String?
  requestedAt   DateTime  @default(now())
  reviewedAt    DateTime?
  completedAt   DateTime?

  seller User @relation(fields: [sellerId], references: [id])

  @@map("withdrawals")
}

model SmsLog {
  id              String    @id @default(uuid())
  phone           String
  templateCode    String?
  content         String?
  variables       String?
  status          String?
  gatewayResponse String?
  sentAt          DateTime?
  createdAt       DateTime  @default(now())

  @@map("sms_logs")
}

model VerificationCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  purpose   String   @default("LOGIN")
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("verification_codes")
}

model SellerApplication {
  id           String   @id @default(uuid())
  userId       String?
  phone        String
  username     String
  age          Int?
  gender       String?
  location     String?
  bio          String?
  reason       String?
  experience   String?
  gameIds      String   @default("[]")
  status       String   @default("PENDING")
  reviewedBy   String?
  reviewNote   String?
  submittedAt  DateTime @default(now())
  reviewedAt   DateTime?

  @@map("seller_applications")
}

model ActivityLog {
  id          String    @id @default(uuid())
  userId      String?
  action      String
  entityType  String?
  entityId    String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String?
  guestId     String?
  guestName   String?
  adminId     String?
  subject     String
  status      String   @default("OPEN")
  priority    String   @default("NORMAL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User?          @relation("UserSupportTickets", fields: [userId], references: [id])
  admin   User?          @relation("AdminSupportTickets", fields: [adminId], references: [id])
  replies SupportReply[]

  @@map("support_tickets")
}

model SupportReply {
  id        String   @id @default(uuid())
  ticketId  String
  senderId  String?
  guestId   String?
  guestName String?
  isAdmin   Boolean  @default(false)
  content   String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  admin  User?         @relation("AdminReplies", fields: [senderId], references: [id])

  @@map("support_replies")
}
